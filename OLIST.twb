      <table>
        <view>
          <datasources>
            <datasource caption='orders+ (OLIST)' name='federated.0tiaivq1k50efa18vju601esyutl' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0tiaivq1k50efa18vju601esyutl'>
            <column caption='Delivery Delay' datatype='integer' name='[Calculation_2467916987482113]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_estimated_delivery_date], [order_delivered_customer_date])' />
            </column>
            <column caption='State' datatype='string' name='[Calculation_2467917000388613]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
              <calculation class='tableau' formula='CASE [customer_state]&#13;&#10;WHEN &quot;SP&quot; THEN &quot;São Paulo&quot;&#13;&#10;WHEN &quot;RJ&quot; THEN &quot;Rio de Janeiro&quot;&#13;&#10;WHEN &quot;MG&quot; THEN &quot;Minas Gerais&quot;&#13;&#10;WHEN &quot;RS&quot; THEN &quot;Rio Grande do Sul&quot;&#13;&#10;WHEN &quot;PR&quot; THEN &quot;Paraná&quot;&#13;&#10;WHEN &quot;SC&quot; THEN &quot;Santa Catarina&quot;&#13;&#10;WHEN &quot;BA&quot; THEN &quot;Bahia&quot;&#13;&#10;WHEN &quot;GO&quot; THEN &quot;Goiás&quot;&#13;&#10;WHEN &quot;ES&quot; THEN &quot;Espírito Santo&quot;&#13;&#10;WHEN &quot;PE&quot; THEN &quot;Pernambuco&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
            </column>
            <column-instance column='[Calculation_2467916987482113]' derivation='Avg' name='[avg:Calculation_2467916987482113:qk]' pivot='key' type='quantitative' />
            <column caption='Customer State' datatype='string' name='[customer_state]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column-instance column='[Calculation_2467917000388613]' derivation='None' name='[none:Calculation_2467917000388613:nk]' pivot='key' type='nominal' />
            <column caption='Order Delivered Customer Date' datatype='datetime' name='[order_delivered_customer_date]' role='dimension' type='ordinal' />
            <column caption='Order Estimated Delivery Date' datatype='date' name='[order_estimated_delivery_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_2467916987482113]' derivation='Sum' name='[sum:Calculation_2467916987482113:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <shelf-sorts>
            <shelf-sort-v2 dimension-to-sort='[federated.0tiaivq1k50efa18vju601esyutl].[none:Calculation_2467917000388613:nk]' direction='ASC' is-on-innermost-dimension='true' measure-to-sort-by='[federated.0tiaivq1k50efa18vju601esyutl].[avg:Calculation_2467916987482113:qk]' shelf='rows' />
          </shelf-sorts>
