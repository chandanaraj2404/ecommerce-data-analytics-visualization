          <datasource-dependencies datasource='federated.0tiaivq1k50efa18vju601esyutl'>
            <column caption='Delivery Time' datatype='integer' name='[Calculation_2467916987314176]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_purchase_timestamp], [order_delivered_customer_date])' />
