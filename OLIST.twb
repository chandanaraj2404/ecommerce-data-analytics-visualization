      <aliases enabled='yes' />
      <column caption='Delivery Time' datatype='integer' name='[Calculation_2467916987314176]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_purchase_timestamp], [order_delivered_customer_date])' />
      </column>
      <column caption='Delivery Delay' datatype='integer' name='[Calculation_2467916987482113]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_estimated_delivery_date], [order_delivered_customer_date])' />
      </column>
      <column caption='Calculation1' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_2467916987596802]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2467916987482113] &lt;= 0 THEN &quot;On Time&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='On-Time  Flag' datatype='string' name='[Calculation_2467916987772931]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2467916987482113] &lt;= 0 THEN &quot;On Time&quot;&#13;&#10;ELSE &quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='State' datatype='string' name='[Calculation_2467917000388613]' role='dimension' semantic-role='[State].[Name]' type='nominal'>
        <calculation class='tableau' formula='CASE [customer_state]&#13;&#10;WHEN &quot;SP&quot; THEN &quot;São Paulo&quot;&#13;&#10;WHEN &quot;RJ&quot; THEN &quot;Rio de Janeiro&quot;&#13;&#10;WHEN &quot;MG&quot; THEN &quot;Minas Gerais&quot;&#13;&#10;WHEN &quot;RS&quot; THEN &quot;Rio Grande do Sul&quot;&#13;&#10;WHEN &quot;PR&quot; THEN &quot;Paraná&quot;&#13;&#10;WHEN &quot;SC&quot; THEN &quot;Santa Catarina&quot;&#13;&#10;WHEN &quot;BA&quot; THEN &quot;Bahia&quot;&#13;&#10;WHEN &quot;GO&quot; THEN &quot;Goiás&quot;&#13;&#10;WHEN &quot;ES&quot; THEN &quot;Espírito Santo&quot;&#13;&#10;WHEN &quot;PE&quot; THEN &quot;Pernambuco&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Absolute Delivery Delay' datatype='integer' name='[Calculation_2467917001617414]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([Calculation_2467916987482113])' />
      </column>
      <column caption='Fix' datatype='string' name='[Calculation_2467917002620935]' role='dimension' semantic-role='[County].[Name]' type='nominal'>
        <calculation class='tableau' formula='&quot;Brazil - &quot; + [Calculation_2467917000388613]' />
      </column>
      <column caption='OutlierFlag' datatype='string' name='[Calculation_2467917007310856]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2467916987482113] &gt; 50 OR [Calculation_2467916987482113] &lt; -50 THEN &quot;Outlier&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column aggregation='None' caption='Delivery Delay (bin)' datatype='integer' name='[Delivery Delay (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[Calculation_2467916987482113]' peg='0' size='10' />
      </column>
